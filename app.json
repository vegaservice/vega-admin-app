{
  "expo": {
    "name": "VEGA Admin",
    "slug": "vega-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0800"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vegavizag.admin",
      "buildNumber": "1",
      "appleTeamId": "73RYNYV3JU",
      "infoPlist": {
        "NSCameraUsageDescription": "VEGA Admin needs camera access for service verification photos",
        "NSPhotoLibraryUsageDescription": "VEGA Admin needs photo access for service documentation",
        "NSLocationWhenInUseUsageDescription": "VEGA Admin needs location to monitor service areas"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A4E"
      },
      "package": "com.vegavizag.admin",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "android": {
            "googleServicesFile": "./google-services.json"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a2cb81a3-7b99-49f5-9ec4-6ace8e81d762"
      }
    },
    "owner": "mahesh1331"
  }
}
